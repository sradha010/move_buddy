generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_URL")
}

enum Role {
  guest
  host
  admin
}

enum ActiveMode {
  guest
  host
}

enum DocumentStatus {
  pending
  approved
  rejected
}

enum RideStatus {
  open
  full
  active
  completed
  cancelled
}

enum RequestStatus {
  pending
  accepted
  rejected
  cancelled
  completed
}

enum PaymentStatus {
  pending
  completed
  failed
  refunded
}

enum NotificationType {
  otp_sent
  ride_requested
  ride_accepted
  ride_rejected
  ride_completed
  subscription_purchased
  subscription_expiry
  payment_success
  payment_failed
}

enum SubscriptionStatus {
  active
  expired
  cancelled
}

enum VehicleStatus {
  active
  inactive
}

model User {
  id            String     @id @default(uuid())
  name          String
  email         String?    @unique
  phone         String     @unique
  password_hash String?
  profile_photo String?
  role          Role       @default(guest)
  active_mode   ActiveMode @default(guest)
  is_verified   Boolean    @default(false)
  is_suspended  Boolean    @default(false)
  created_at    DateTime   @default(now())
  updated_at    DateTime   @updatedAt

  otp_verifications      OtpVerification[]
  refresh_tokens         RefreshToken[]
  vehicles               Vehicle[]
  documents              UserDocument?
  rides_offered          Ride[]         @relation("HostRides")
  ride_requests          RideRequest[]  @relation("GuestRequests")
  subscriptions          Subscription[]
  payments               Payment[]
  sent_notifications     Notification[] @relation("SentNotifications")
  received_notifications Notification[] @relation("ReceivedNotifications")
  reviews_given          Review[]       @relation("ReviewsGiven")
  reviews_received       Review[]       @relation("ReviewsReceived")
  reports_made           Report[]       @relation("ReportsMade")
  reports_against        Report[]       @relation("ReportsAgainst")
  audit_logs             AuditLog[]

  @@map("users")
}

model OtpVerification {
  id         String   @id @default(uuid())
  user_id    String
  phone      String
  otp_hash   String
  expires_at DateTime
  attempts   Int      @default(0)
  is_used    Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("otp_verifications")
}

model RefreshToken {
  id         String   @id @default(uuid())
  user_id    String
  token_hash String   @unique
  expires_at DateTime
  is_revoked Boolean  @default(false)
  created_at DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Vehicle {
  id             String        @id @default(uuid())
  owner_id       String
  vehicle_type   String
  vehicle_number String        @unique
  vehicle_model  String
  vehicle_color  String
  status         VehicleStatus @default(active)
  created_at     DateTime      @default(now())
  updated_at     DateTime      @updatedAt

  owner User   @relation(fields: [owner_id], references: [id], onDelete: Cascade)
  rides Ride[]

  @@map("vehicles")
}

model UserDocument {
  id                     String         @id @default(uuid())
  user_id                String         @unique
  aadhaar_url            String?
  driving_license_url    String?
  vehicle_rc_url         String?
  insurance_url          String?
  aadhaar_number         String?
  driving_license_number String?
  status                 DocumentStatus @default(pending)
  reviewed_by            String?
  reviewed_at            DateTime?
  rejection_reason       String?
  created_at             DateTime       @default(now())
  updated_at             DateTime       @updatedAt

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)

  @@map("user_documents")
}

model Ride {
  id                  String     @id @default(uuid())
  host_id             String
  vehicle_id          String?
  origin_address      String
  origin_lat          Float
  origin_lng          Float
  destination_address String
  destination_lat     Float
  destination_lng     Float
  distance_km         Float
  duration_minutes    Int
  departure_time      DateTime
  price_per_km        Float
  total_price         Float
  available_seats     Int
  total_seats         Int
  status              RideStatus @default(open)
  route_polyline      String?
  created_at          DateTime   @default(now())
  updated_at          DateTime   @updatedAt

  host     User          @relation("HostRides", fields: [host_id], references: [id])
  vehicle  Vehicle?      @relation(fields: [vehicle_id], references: [id])
  requests RideRequest[]
  reviews  Review[]

  @@map("rides")
}

model RideRequest {
  id                String        @id @default(uuid())
  ride_id           String
  guest_id          String
  pickup_address    String?
  pickup_lat        Float?
  pickup_lng        Float?
  dropoff_address   String?
  dropoff_lat       Float?
  dropoff_lng       Float?
  route_overlap_pct Float?
  status            RequestStatus @default(pending)
  fare              Float?
  created_at        DateTime      @default(now())
  updated_at        DateTime      @updatedAt

  ride  Ride @relation(fields: [ride_id], references: [id], onDelete: Cascade)
  guest User @relation("GuestRequests", fields: [guest_id], references: [id])

  @@map("ride_requests")
}

model PricingConfig {
  id           String   @id @default(uuid())
  per_km_rate  Float    @default(6.0)
  rapido_rate  Float    @default(7.0)
  auto_rate    Float    @default(8.0)
  ola_rate     Float    @default(10.0)
  uber_rate    Float    @default(12.0)
  updated_by   String?
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt

  @@map("pricing_config")
}

model PricingHistory {
  id          String   @id @default(uuid())
  per_km_rate Float
  changed_by  String
  reason      String?
  created_at  DateTime @default(now())

  @@map("pricing_history")
}

model Subscription {
  id           String             @id @default(uuid())
  user_id      String
  plan_type    String
  plan_days    Int
  discount_pct Float              @default(0)
  price_paid   Float
  started_at   DateTime           @default(now())
  ends_at      DateTime
  status       SubscriptionStatus @default(active)
  payment_id   String?
  created_at   DateTime           @default(now())
  updated_at   DateTime           @updatedAt

  user User @relation(fields: [user_id], references: [id])

  @@map("subscriptions")
}

model Payment {
  id           String        @id @default(uuid())
  user_id      String
  order_id     String        @unique
  payment_id   String?       @unique
  amount       Float
  currency     String        @default("INR")
  status       PaymentStatus @default(pending)
  signature    String?
  payment_type String
  reference_id String?
  created_at   DateTime      @default(now())
  updated_at   DateTime      @updatedAt

  user User         @relation(fields: [user_id], references: [id])
  logs PaymentLog[]

  @@map("payments")
}

model PaymentLog {
  id         String   @id @default(uuid())
  payment_id String
  event      String
  data       Json
  created_at DateTime @default(now())

  payment Payment @relation(fields: [payment_id], references: [id])

  @@map("payment_logs")
}

model Notification {
  id          String           @id @default(uuid())
  sender_id   String?
  receiver_id String
  type        NotificationType
  title       String
  message     String
  data        Json?
  is_read     Boolean          @default(false)
  created_at  DateTime         @default(now())

  sender   User? @relation("SentNotifications", fields: [sender_id], references: [id])
  receiver User  @relation("ReceivedNotifications", fields: [receiver_id], references: [id])

  @@map("notifications")
}

model Review {
  id          String   @id @default(uuid())
  ride_id     String
  reviewer_id String
  reviewee_id String
  rating      Int
  comment     String?
  created_at  DateTime @default(now())

  ride     Ride @relation(fields: [ride_id], references: [id])
  reviewer User @relation("ReviewsGiven", fields: [reviewer_id], references: [id])
  reviewee User @relation("ReviewsReceived", fields: [reviewee_id], references: [id])

  @@unique([ride_id, reviewer_id])
  @@map("reviews")
}

model Report {
  id               String    @id @default(uuid())
  reporter_id      String
  reported_user_id String?
  reported_ride_id String?
  reason           String
  description      String?
  status           String    @default("open")
  resolved_by      String?
  resolved_at      DateTime?
  created_at       DateTime  @default(now())

  reporter      User  @relation("ReportsMade", fields: [reporter_id], references: [id])
  reported_user User? @relation("ReportsAgainst", fields: [reported_user_id], references: [id])

  @@map("reports")
}

model Branding {
  id            String   @id @default(uuid())
  logo_url      String?
  primary_color String   @default("#FF7D00")
  navbar_links  Json     @default("[]")
  updated_by    String?
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  @@map("branding")
}

model AuditLog {
  id          String   @id @default(uuid())
  user_id     String
  action      String
  entity_type String?
  entity_id   String?
  old_value   Json?
  new_value   Json?
  ip_address  String?
  user_agent  String?
  created_at  DateTime @default(now())

  user User @relation(fields: [user_id], references: [id])

  @@map("audit_logs")
}

model UserPreference {
  id                    String     @id @default(uuid())
  user_id               String     @unique
  notifications_enabled Boolean    @default(true)
  sms_enabled           Boolean    @default(true)
  email_notifications   Boolean    @default(false)
  default_mode          ActiveMode @default(guest)
  created_at            DateTime   @default(now())
  updated_at            DateTime   @updatedAt

  @@map("user_preferences")
}
